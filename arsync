#!/usr/bin/env bash

set -euo pipefail

log() {
  printf '[arsync] %s\n' "$1"
}

sync_nvim() {
  local source_dir="$repo_root/nvim/.config"
  local target_dir="$HOME/.config/nvim"
  local backup_dir="$backup_root/.config/nvim"

  log 'processing package: nvim'

  mkdir -p "$HOME/.config"

  if [[ -e "$target_dir" && ! -L "$target_dir" ]]; then
    mkdir -p "$(dirname "$backup_dir")"
    mv "$target_dir" "$backup_dir"
    log "backed up $target_dir -> $backup_dir"
  else
    log 'no backups needed for nvim'
  fi

  rm -f "$HOME/.config/init.lua" "$HOME/.config/lazy-lock.json" "$HOME/.config/README.md"

  if [[ -L "$HOME/.config/lua" && "$(readlink -f "$HOME/.config/lua")" == "$source_dir/lua" ]]; then
    rm -f "$HOME/.config/lua"
  fi

  log 'linking ~/.config/nvim'
  ln -sfn "$source_dir" "$target_dir"
}

profile="${1:-arch}"
script_path="$(readlink -f "${BASH_SOURCE[0]}")"
repo_root="$(cd "$(dirname "$script_path")" && pwd)"
backup_root="$HOME/.dotfiles_backup/$(date +%Y%m%d_%H%M%S)"

if ! command -v stow >/dev/null 2>&1; then
  printf 'stow is required but not installed\n' >&2
  exit 1
fi

packages=(zsh tmux scripts)

case "$profile" in
  arch)
    packages+=(ranger i3 hypr waybar rofi sublime-text)
    ;;
  mac)
    packages+=(sublime-text)
    ;;
  *)
    printf 'usage: %s [arch|mac]\n' "$0" >&2
    exit 1
    ;;
esac

log "profile: $profile"
log "packages: ${packages[*]}"

sync_nvim

for package in "${packages[@]}"; do
  log "processing package: $package"
  backed_up=0

  while IFS= read -r source_path; do
    rel_path="${source_path#${repo_root}/${package}/}"
    target_path="$HOME/$rel_path"

    if [[ -e "$target_path" && ! -L "$target_path" ]]; then
      mkdir -p "$backup_root/$(dirname "$rel_path")"
      mv "$target_path" "$backup_root/$rel_path"
      log "backed up $target_path -> $backup_root/$rel_path"
      backed_up=1
    fi
  done < <(find "$repo_root/$package" -type f)

  if [[ $backed_up -eq 0 ]]; then
    log "no backups needed for $package"
  fi

  log "stowing $package"
  stow --restow --target="$HOME" --dir="$repo_root" "$package"
done

if [[ -d "$backup_root" ]]; then
  log "backups stored in $backup_root"
fi

log 'sync complete'
